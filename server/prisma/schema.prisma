generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  manager
  finance
  warehouse
  staff
}

enum ConversationType {
  direct
  group
  bot
}

enum ConversationMemberRole {
  admin
  member
}

enum MessageType {
  text
  invoice
  stock_alert
  expense
  shipment
  command
  system
}

enum InvoiceStatus {
  pending
  approved
  rejected
  overdue
  paid
}

enum ExpenseCategory {
  travel
  supplies
  utilities
  salary
  marketing
  other
}

enum BudgetPeriod {
  monthly
  quarterly
  yearly
}

enum StockAlertType {
  low_stock
  out_of_stock
  overstock
}

enum StockAlertStatus {
  active
  dismissed
  resolved
}

enum OrderStatus {
  pending
  packed
  dispatched
  in_transit
  delivered
  cancelled
}

enum StockMovementType {
  in
  out
  transfer
  adjustment
}

enum NotificationType {
  invoice_pending
  invoice_approved
  invoice_rejected
  low_stock
  order_update
  new_message
  mention
  expense_logged
}

model User {
  id                   String               @id @default(uuid()) @db.Uuid
  name                 String
  email                String               @unique
  password             String
  avatarUrl            String?              @map("avatar_url")
  role                 UserRole
  department           String?
  isOnline             Boolean              @default(false) @map("is_online")
  lastSeen             DateTime?            @map("last_seen")
  createdAt            DateTime             @default(now()) @map("created_at")
  conversationsCreated Conversation[]       @relation("ConversationCreatedBy")
  memberships          ConversationMember[]
  messagesSent         Message[]            @relation("MessageSender")
  reactions            MessageReaction[]
  createdInvoices      Invoice[]            @relation("InvoiceCreatedBy")
  approvedInvoices     Invoice[]            @relation("InvoiceApprovedBy")
  rejectedInvoices     Invoice[]            @relation("InvoiceRejectedBy")
  expensesLogged       Expense[]
  budgetsCreated       Budget[]
  ordersCreated        Order[]
  stockMovements       StockMovement[]
  notifications        Notification[]

  @@map("users")
}

model Conversation {
  id          String               @id @default(uuid()) @db.Uuid
  type        ConversationType
  name        String?
  createdById String?              @map("created_by") @db.Uuid
  createdAt   DateTime             @default(now()) @map("created_at")
  createdBy   User?                @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  members     ConversationMember[]
  messages    Message[]
  invoices    Invoice[]
  expenses    Expense[]
  stockAlerts StockAlert[]
  orders      Order[]

  @@map("conversations")
}

model ConversationMember {
  id             String                 @id @default(uuid()) @db.Uuid
  conversationId String                 @map("conversation_id") @db.Uuid
  userId         String                 @map("user_id") @db.Uuid
  role           ConversationMemberRole @default(member)
  unreadCount    Int                    @default(0) @map("unread_count")
  lastReadAt     DateTime?              @map("last_read_at")
  joinedAt       DateTime               @default(now()) @map("joined_at")
  conversation   Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String            @id @default(uuid()) @db.Uuid
  conversationId String            @map("conversation_id") @db.Uuid
  senderId       String            @map("sender_id") @db.Uuid
  type           MessageType       @default(text)
  content        String
  metadata       Json?
  isPinned       Boolean           @default(false) @map("is_pinned")
  replyToId      String?           @map("reply_to_id") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User              @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo        Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        Message[]         @relation("MessageReplies")
  reactions      MessageReaction[]
  attachments    Attachment[]
  invoice        Invoice?
  expense        Expense?
  stockAlert     StockAlert?
  order          Order?

  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

model Attachment {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  fileUrl   String   @map("file_url")
  fileName  String   @map("file_name")
  fileType  String   @map("file_type")
  fileSize  Int      @map("file_size")
  createdAt DateTime @default(now()) @map("created_at")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Invoice {
  id              String        @id @default(uuid()) @db.Uuid
  invoiceNumber   String        @unique @map("invoice_number")
  companyName     String        @map("company_name")
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("USD")
  dueDate         DateTime      @db.Date @map("due_date")
  status          InvoiceStatus @default(pending)
  createdById     String        @map("created_by") @db.Uuid
  approvedById    String?       @map("approved_by") @db.Uuid
  rejectedById    String?       @map("rejected_by") @db.Uuid
  rejectionReason String?       @map("rejection_reason")
  conversationId  String        @map("conversation_id") @db.Uuid
  messageId       String        @unique @map("message_id") @db.Uuid
  pdfUrl          String?       @map("pdf_url")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  createdBy       User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy      User?         @relation("InvoiceApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy      User?         @relation("InvoiceRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message         Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Expense {
  id             String          @id @default(uuid()) @db.Uuid
  amount         Decimal         @db.Decimal(12, 2)
  currency       String          @default("USD")
  category       ExpenseCategory
  note           String
  loggedById     String          @map("logged_by") @db.Uuid
  conversationId String          @map("conversation_id") @db.Uuid
  messageId      String          @unique @map("message_id") @db.Uuid
  receiptUrl     String?         @map("receipt_url")
  createdAt      DateTime        @default(now()) @map("created_at")
  loggedBy       User            @relation(fields: [loggedById], references: [id], onDelete: Restrict)
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message         @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Budget {
  id          String       @id @default(uuid()) @db.Uuid
  department  String
  totalAmount Decimal      @db.Decimal(12, 2) @map("total_amount")
  spentAmount Decimal      @default(0) @db.Decimal(12, 2) @map("spent_amount")
  period      BudgetPeriod
  startDate   DateTime     @db.Date @map("start_date")
  endDate     DateTime     @db.Date @map("end_date")
  createdById String       @map("created_by") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@map("budgets")
}

model Product {
  id                String          @id @default(uuid()) @db.Uuid
  name              String
  sku               String          @unique
  description       String
  category          String
  unit              String
  currentStock      Int             @map("current_stock")
  minimumStock      Int             @map("minimum_stock")
  reorderQuantity   Int             @map("reorder_quantity")
  warehouseLocation String          @map("warehouse_location")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  stockAlerts       StockAlert[]
  orders            Order[]
  stockMovements    StockMovement[]

  @@map("products")
}

model StockAlert {
  id             String           @id @default(uuid()) @db.Uuid
  productId      String           @map("product_id") @db.Uuid
  alertType      StockAlertType   @map("alert_type")
  currentStock   Int              @map("current_stock")
  minimumStock   Int              @map("minimum_stock")
  status         StockAlertStatus @default(active)
  triggeredAt    DateTime         @default(now()) @map("triggered_at")
  resolvedAt     DateTime?        @map("resolved_at")
  conversationId String           @map("conversation_id") @db.Uuid
  messageId      String           @unique @map("message_id") @db.Uuid
  product        Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message          @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("stock_alerts")
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  orderNumber       String      @unique @map("order_number")
  productId         String      @map("product_id") @db.Uuid
  quantity          Int
  status            OrderStatus @default(pending)
  supplierName      String      @map("supplier_name")
  destination       String
  estimatedDelivery DateTime    @db.Date @map("estimated_delivery")
  actualDelivery    DateTime?   @db.Date @map("actual_delivery")
  createdById       String      @map("created_by") @db.Uuid
  conversationId    String      @map("conversation_id") @db.Uuid
  messageId         String      @unique @map("message_id") @db.Uuid
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  product           Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy         User        @relation(fields: [createdById], references: [id], onDelete: Restrict)
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message           Message     @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model StockMovement {
  id            String            @id @default(uuid()) @db.Uuid
  productId     String            @map("product_id") @db.Uuid
  movementType  StockMovementType @map("movement_type")
  quantity      Int
  fromLocation  String?           @map("from_location")
  toLocation    String?           @map("to_location")
  reason        String
  performedById String            @map("performed_by") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at")
  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  performedBy   User              @relation(fields: [performedById], references: [id], onDelete: Restrict)

  @@map("stock_movements")
}

model Notification {
  id            String           @id @default(uuid()) @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  type          NotificationType
  title         String
  body          String
  referenceId   String?          @map("reference_id") @db.Uuid
  referenceType String           @map("reference_type")
  isRead        Boolean          @default(false) @map("is_read")
  createdAt     DateTime         @default(now()) @map("created_at")
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
